{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["chrome", "wxt/browser"]
  },
  "include": ["src/**/*", ".wxt/types/**/*"]
}
